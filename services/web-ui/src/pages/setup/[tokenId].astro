---
import SetupLayout from "../../layouts/SetupLayout.astro";
import "../../styles/global.css";
import { getUserManagementClient } from "../../lib/user-management-client";
import { getTimezoneGroups } from "../../lib/timezones";

const { tokenId } = Astro.params;
const sig = Astro.url.searchParams.get("sig");
const csrfToken = Astro.locals.csrfToken;

let isValid = false;
let telegramUserId = "";
let step = "";
let expiresAt = "";
let errorMessage = "";

if (!tokenId || !sig) {
	errorMessage = "Invalid setup link. Please return to Telegram to request a new setup link.";
} else {
	try {
		const client = getUserManagementClient();
		const response = await client.fetch(
			`/internal/setup-tokens/${tokenId}/validate?sig=${encodeURIComponent(sig)}`,
		);

		if (response.ok) {
			const data = await response.json();
			if (data.valid) {
				isValid = true;
				telegramUserId = data.telegramUserId;
				step = data.step;
				expiresAt = data.expiresAt;
			} else {
				errorMessage =
					"This link has expired or already been used. Please return to Telegram to request a new setup link.";
			}
		} else if (response.status === 403) {
			errorMessage =
				"This link is invalid. Please return to Telegram to request a new setup link.";
		} else {
			errorMessage = "An error occurred while validating your setup link. Please try again.";
		}
	} catch {
		errorMessage =
			"Unable to validate your setup link at this time. Please try again later.";
	}
}

const languages = [
	{ value: "en", label: "English" },
	{ value: "fr", label: "French" },
	{ value: "de", label: "German" },
	{ value: "es", label: "Spanish" },
	{ value: "pt", label: "Portuguese" },
	{ value: "it", label: "Italian" },
	{ value: "nl", label: "Dutch" },
	{ value: "ru", label: "Russian" },
	{ value: "zh", label: "Chinese" },
	{ value: "ja", label: "Japanese" },
];

const timezoneGroups = getTimezoneGroups();
---

<SetupLayout title="Monica Companion — Setup">
	{isValid ? (
		<div>
			<div class="mb-8">
				<h1 class="text-2xl font-bold tracking-tight sm:text-3xl">Set up your companion</h1>
				<p class="mt-2 text-text-muted">
					Connect your Monica CRM and configure your preferences to get started.
				</p>
			</div>

			<form method="POST" action="/setup/submit" id="onboarding-form" class="space-y-6">
				<input type="hidden" name="csrf_token" value={csrfToken} />
				<input type="hidden" name="tokenId" value={tokenId} />
				<input type="hidden" name="sig" value={sig} />

				<!-- Step 1: Monica Connection -->
				<section class="rounded-xl border border-border bg-bg-card p-5 shadow-sm">
					<div class="mb-4 flex items-center gap-2.5">
						<div class="flex h-7 w-7 items-center justify-center rounded-full bg-bg-accent text-xs font-semibold text-text-inverse">1</div>
						<h2 class="text-base font-semibold">Monica CRM Connection</h2>
					</div>

					<div class="space-y-4">
						<div>
							<label for="monicaBaseUrl" class="mb-1.5 block text-sm font-medium">
								Monica Base URL
							</label>
							<input
								type="url"
								id="monicaBaseUrl"
								name="monicaBaseUrl"
								required
								placeholder="https://app.monicahq.com"
								class="focus-ring block w-full rounded-lg border border-border-input bg-bg-input px-3.5 py-2.5 text-sm text-text placeholder:text-text-muted transition-colors focus:border-border-focus"
							/>
							<p class="mt-1.5 text-xs text-text-muted">
								Your Monica instance URL without /api. Must use HTTPS.
							</p>
						</div>

						<div>
							<label for="monicaApiKey" class="mb-1.5 block text-sm font-medium">
								API Key
							</label>
							<input
								type="password"
								id="monicaApiKey"
								name="monicaApiKey"
								required
								minlength="1"
								placeholder="Your Monica API token"
								class="focus-ring block w-full rounded-lg border border-border-input bg-bg-input px-3.5 py-2.5 text-sm text-text font-mono placeholder:font-sans placeholder:text-text-muted transition-colors focus:border-border-focus"
							/>
							<p class="mt-1.5 text-xs text-text-muted">
								Find this in Monica under Settings &rarr; API.
							</p>
						</div>
					</div>
				</section>

				<!-- Step 2: Preferences -->
				<section class="rounded-xl border border-border bg-bg-card p-5 shadow-sm">
					<div class="mb-4 flex items-center gap-2.5">
						<div class="flex h-7 w-7 items-center justify-center rounded-full bg-bg-accent text-xs font-semibold text-text-inverse">2</div>
						<h2 class="text-base font-semibold">Preferences</h2>
					</div>

					<div class="space-y-4">
						<div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
							<div>
								<label for="language" class="mb-1.5 block text-sm font-medium">
									Language
								</label>
								<select
									id="language"
									name="language"
									class="focus-ring block w-full rounded-lg border border-border-input bg-bg-input px-3.5 py-2.5 text-sm text-text transition-colors focus:border-border-focus"
								>
									{languages.map(l => (
										<option value={l.value} selected={l.value === "en"}>{l.label}</option>
									))}
								</select>
							</div>

							<div>
								<label for="confirmationMode" class="mb-1.5 block text-sm font-medium">
									Confirmation Mode
								</label>
								<select
									id="confirmationMode"
									name="confirmationMode"
									class="focus-ring block w-full rounded-lg border border-border-input bg-bg-input px-3.5 py-2.5 text-sm text-text transition-colors focus:border-border-focus"
								>
									<option value="explicit" selected>Ask before changes</option>
									<option value="auto">Apply immediately</option>
								</select>
							</div>
						</div>

						<div>
							<label for="tz-search" class="mb-1.5 block text-sm font-medium">
								Timezone
							</label>
							<div class="relative">
								<input
									type="text"
									id="tz-search"
									placeholder="Search timezones..."
									autocomplete="off"
									class="focus-ring block w-full rounded-lg border border-border-input bg-bg-input px-3.5 py-2.5 pr-10 text-sm text-text placeholder:text-text-muted transition-colors focus:border-border-focus"
								/>
								<svg class="pointer-events-none absolute right-3 top-1/2 h-4 w-4 -translate-y-1/2 text-text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
									<path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
								</svg>
							</div>
							<select
								id="timezone"
								name="timezone"
								required
								size="6"
								class="focus-ring mt-2 block w-full rounded-lg border border-border-input bg-bg-input text-sm text-text transition-colors focus:border-border-focus"
							>
								{timezoneGroups.map(group => (
									<optgroup label={group.region}>
										{group.timezones.map(tz => (
											<option value={tz.value} class="px-3 py-1.5">
												{tz.label} ({tz.offset})
											</option>
										))}
									</optgroup>
								))}
							</select>
							<input type="hidden" id="tz-detected" />
							<p class="mt-1.5 text-xs text-text-muted" id="tz-detected-label"></p>
						</div>
					</div>
				</section>

				<!-- Step 3: Reminders -->
				<section class="rounded-xl border border-border bg-bg-card p-5 shadow-sm">
					<div class="mb-4 flex items-center gap-2.5">
						<div class="flex h-7 w-7 items-center justify-center rounded-full bg-bg-accent text-xs font-semibold text-text-inverse">3</div>
						<h2 class="text-base font-semibold">Reminders</h2>
					</div>

					<div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
						<div>
							<label for="reminderCadence" class="mb-1.5 block text-sm font-medium">
								Frequency
							</label>
							<select
								id="reminderCadence"
								name="reminderCadence"
								class="focus-ring block w-full rounded-lg border border-border-input bg-bg-input px-3.5 py-2.5 text-sm text-text transition-colors focus:border-border-focus"
							>
								<option value="daily" selected>Daily</option>
								<option value="weekly">Weekly</option>
								<option value="none">None</option>
							</select>
						</div>

						<div>
							<label for="reminderTime" class="mb-1.5 block text-sm font-medium">
								Time
							</label>
							<input
								type="time"
								id="reminderTime"
								name="reminderTime"
								value="08:00"
								class="focus-ring block w-full rounded-lg border border-border-input bg-bg-input px-3.5 py-2.5 text-sm text-text transition-colors focus:border-border-focus"
							/>
						</div>
					</div>
				</section>

				<!-- Submit -->
				<button
					type="submit"
					class="focus-ring w-full rounded-xl bg-bg-accent px-6 py-3 text-sm font-semibold text-text-inverse shadow-sm transition-colors hover:bg-bg-accent-hover active:scale-[0.98]"
				>
					Complete Setup
				</button>
			</form>
		</div>
	) : (
		<div class="flex flex-1 items-center justify-center">
			<div class="rounded-xl border border-border bg-bg-card p-8 text-center shadow-md">
				<div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-bg-destructive/10">
					<svg class="h-6 w-6 text-text-destructive" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
						<path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" />
					</svg>
				</div>
				<h1 class="text-lg font-semibold">Setup Error</h1>
				<p class="mt-2 text-sm text-text-muted">{errorMessage}</p>
			</div>
		</div>
	)}

	<script>
		// Auto-detect timezone and pre-select
		(function () {
			const select = document.getElementById("timezone") as HTMLSelectElement | null;
			const search = document.getElementById("tz-search") as HTMLInputElement | null;
			const label = document.getElementById("tz-detected-label");
			if (!select) return;

			// Auto-detect and pre-select user's timezone
			try {
				const detected = Intl.DateTimeFormat().resolvedOptions().timeZone;
				if (detected) {
					for (const opt of select.options) {
						if (opt.value === detected) {
							opt.selected = true;
							if (label) label.textContent = `Detected: ${detected}`;
							break;
						}
					}
				}
			} catch { /* ignore detection failure */ }

			// Timezone search/filter
			if (search) {
				search.addEventListener("input", () => {
					const query = search.value.toLowerCase();
					for (const opt of select.options) {
						if (opt.value === "") continue;
						const text = `${opt.value} ${opt.textContent}`.toLowerCase();
						opt.hidden = query.length > 0 && !text.includes(query);
					}
					// Show/hide optgroups
					for (const group of select.querySelectorAll("optgroup")) {
						const visible = Array.from(group.querySelectorAll("option")).some(o => !o.hidden);
						(group as HTMLOptGroupElement).hidden = !visible;
					}
				});
			}
		})();

		// Client-side URL validation
		const form = document.getElementById("onboarding-form");
		if (form) {
			form.addEventListener("submit", function (e) {
				const urlInput = document.getElementById("monicaBaseUrl") as HTMLInputElement | null;
				if (urlInput?.value) {
					try {
						const url = new URL(urlInput.value);
						if (url.protocol !== "https:") {
							e.preventDefault();
							showError(urlInput, "Only HTTPS URLs are allowed.");
							return;
						}
					} catch {
						e.preventDefault();
						showError(urlInput, "Please enter a valid URL.");
						return;
					}
				}

				const tzSelect = document.getElementById("timezone") as HTMLSelectElement | null;
				if (tzSelect && !tzSelect.value) {
					e.preventDefault();
					showError(tzSelect, "Please select your timezone.");
					return;
				}
			});
		}

		function showError(el: HTMLElement, msg: string) {
			// Remove any existing error
			const existing = el.parentElement?.querySelector(".field-error");
			if (existing) existing.remove();

			const err = document.createElement("p");
			err.className = "field-error mt-1.5 text-xs text-text-destructive";
			err.textContent = msg;
			el.after(err);
			el.focus();

			// Auto-remove after 5s
			setTimeout(() => err.remove(), 5000);
		}
	</script>
</SetupLayout>
