---
import SetupLayout from "../../layouts/SetupLayout.astro";
import "../../styles/global.css";

const reasonParam = Astro.url.searchParams.get("reason") ?? "unknown";

/** Allowlist of known reason codes to user-friendly messages.
 *  Never render raw query params to prevent XSS. */
const reasonMessages: Record<string, string> = {
	expired: "This setup link has expired. Please return to Telegram to request a new setup link.",
	already_consumed: "This setup link has already been used. Please return to Telegram to request a new setup link.",
	validation_failed: "The information you provided could not be validated. Please try again.",
	server_error: "An error occurred while completing your setup. Please try again later.",
	invalid_url: "The Monica URL you provided is not valid. Please check and try again.",
	not_found: "This setup link is not valid. Please return to Telegram to request a new setup link.",
	unknown: "Something went wrong. Please return to Telegram and request a new setup link.",
};

const message = reasonMessages[reasonParam] ?? reasonMessages.unknown;
---

<SetupLayout title="Monica Companion — Setup Error">
	<div class="flex flex-1 items-center justify-center">
		<div class="max-w-sm rounded-xl border border-border bg-bg-card p-8 text-center shadow-md">
			<div class="mx-auto mb-5 flex h-14 w-14 items-center justify-center rounded-full bg-bg-destructive/10">
				<svg class="h-7 w-7 text-text-destructive" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
					<path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" />
				</svg>
			</div>
			<h1 class="text-xl font-bold tracking-tight">Setup Error</h1>
			<p class="mt-3 text-sm leading-relaxed text-text-muted">{message}</p>
			<div class="mt-6">
				<p class="text-xs text-text-muted">
					Need help? Send <code class="rounded bg-bg-muted px-1.5 py-0.5 font-mono text-text-accent">/start</code> in Telegram to get a new link.
				</p>
			</div>
		</div>
	</div>
</SetupLayout>
