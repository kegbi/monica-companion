# =============================================================================
# Monica Companion — Environment Variables Reference
# =============================================================================
#
# Copy this file to .env and fill in real values.
# For local dev with real credentials, use .env.local (gitignored).
#
# Contexts:
#   Docker  = docker compose --profile app up (services run inside containers)
#   Local   = running services directly with tsx on the host
#   Smoke   = docker compose smoke tests (fake tokens, no real APIs)
#
# Variables marked [required] have no default and must be set.
# Variables marked [optional] have sensible defaults in code.
# Variables marked [docker-only] are hardcoded in docker-compose.yml and
#   only need to be set when running services outside Docker.
#
# =============================================================================


# ── Database ─────────────────────────────────────────────────────────────────
# Used by the postgres container and by services for DB connections.

# Postgres container credentials (used by docker compose)
POSTGRES_USER=monica
POSTGRES_PASSWORD=monica_dev
POSTGRES_DB=monica_companion

# [docker-only] Connection string for services.
# Docker Compose hardcodes this to postgresql://monica:monica_dev@postgres:5432/monica_companion.
# Set this only for local dev (host to docker postgres on mapped port 15432).
DATABASE_URL=postgresql://monica:monica_dev@localhost:15432/monica_companion


# ── Redis ────────────────────────────────────────────────────────────────────

# [docker-only] Redis connection string.
# Docker Compose hardcodes this to redis://redis:6379.
# Set this only for local dev (host to docker redis on mapped port 16379).
REDIS_URL=redis://localhost:16379


# ── Telegram ─────────────────────────────────────────────────────────────────

# [required] Bot token from @BotFather.
# Used by: telegram-bridge
TELEGRAM_BOT_TOKEN=

# [required] Secret token for webhook validation (X-Telegram-Bot-Api-Secret-Token).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Used by: telegram-bridge
TELEGRAM_WEBHOOK_SECRET=


# ── AI / LLM ────────────────────────────────────────────────────────────────

# [required] OpenAI API key for GPT and Whisper.
# Used by: ai-router, voice-transcription
OPENAI_API_KEY=


# ── Auth ─────────────────────────────────────────────────────────────────────

# [required] JWT signing secret for service-to-service auth.
# Must be strong and unique. Used by all services.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-in-production

# [optional] Previous JWT secret for zero-downtime key rotation.
# Set this to the old JWT_SECRET value during rotation, remove after rollout.
JWT_SECRET_PREVIOUS=

# [required] AES-256 key for encrypting Monica credentials at rest.
# Must be exactly 64 hex chars (32 bytes).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Used by: user-management
ENCRYPTION_MASTER_KEY=change-me-in-production-generate-a-real-64-hex-char-key-now

# [optional] Previous encryption key for zero-downtime key rotation.
ENCRYPTION_MASTER_KEY_PREVIOUS=


# ── Setup Tokens (Onboarding) ───────────────────────────────────────────────

# [required] HMAC secret for signing setup links.
# Must be at least 32 characters, cryptographically random, distinct from JWT_SECRET.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Used by: user-management
SETUP_TOKEN_SECRET=change-me-in-production-at-least-32-chars

# [optional] Public-facing base URL where the setup page is accessible (via Caddy).
# Used by: user-management (to build setup links sent to users)
# Default: http://localhost
SETUP_BASE_URL=http://localhost

# [optional] Expected Origin header for CSRF validation on form submissions.
# Must match the domain users see in their browser.
# Used by: web-ui
# Default: http://localhost
EXPECTED_ORIGIN=http://localhost

# [optional] Setup token time-to-live in minutes.
# Used by: user-management
# Default: 15
# SETUP_TOKEN_TTL_MINUTES=15


# ── Monica API (dev/test only) ──────────────────────────────────────────────
# In production, per-user Monica credentials are stored encrypted in the DB.
# These are only used for direct development/testing against a Monica instance.

# Monica instance URL (must be HTTPS in hosted mode)
MONICA_BASE_URL=
# Monica personal access token
MONICA_API_TOKEN=

# [optional] Transport-level timeout for Monica API calls (ms).
# Used by: monica-integration
# Default: 10000
MONICA_DEFAULT_TIMEOUT_MS=10000

# [optional] Max transport-level retries for Monica API calls.
# Used by: monica-integration
# Default: 2
MONICA_RETRY_MAX=2

# [optional] SECURITY: Allow Monica URLs targeting private/loopback IPs.
# Set to "true" ONLY for trusted single-tenant deployments where Monica runs
# on a private network. Default "false" blocks http://, loopback, RFC1918,
# and link-local targets (SSRF protection).
# Used by: monica-integration
# Default: false
ALLOW_PRIVATE_NETWORK_TARGETS=false


# ── Voice Transcription ─────────────────────────────────────────────────────

# [optional] OpenAI transcription model.
# "gpt-4o-transcribe" = better accuracy, token-based pricing.
# "whisper-1" = legacy, cheaper per-minute pricing.
# Used by: voice-transcription
# Default: gpt-4o-transcribe
WHISPER_MODEL=gpt-4o-transcribe

# [optional] Timeout for transcription API calls (ms).
# Default: 60000
WHISPER_TIMEOUT_MS=60000

# [optional] Maximum audio file size in bytes (Whisper API limit is 25MB).
# Default: 26214400 (25MB)
WHISPER_MAX_FILE_SIZE_BYTES=26214400

# [optional] Timeout for downloading audio from fetch URLs (ms).
# Default: 15000
FETCH_URL_TIMEOUT_MS=15000

# [optional] Cost per minute for budget tracking (USD).
# gpt-4o-transcribe = $0.048/min, whisper-1 = $0.006/min.
# Default: 0.048
WHISPER_COST_PER_MINUTE_USD=0.048


# ── Rate Limiting (telegram-bridge) ─────────────────────────────────────────

# [optional] Fixed-window rate limiter for the Telegram webhook endpoint.
# Default: 60 requests per 60000ms (1 minute)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60


# ── Service Timeouts (telegram-bridge to downstream) ────────────────────────

# [optional] Timeout for telegram-bridge calling ai-router (ms). Default: 10000
AI_ROUTER_TIMEOUT_MS=10000

# [optional] Timeout for telegram-bridge calling voice-transcription (ms). Default: 30000
VOICE_TRANSCRIPTION_TIMEOUT_MS=30000

# [optional] Timeout for telegram-bridge calling user-management (ms). Default: 5000
USER_MANAGEMENT_TIMEOUT_MS=5000

# [optional] General HTTP timeout for scheduler, delivery, user-management (ms). Default: 10000
HTTP_TIMEOUT_MS=10000


# ── AI Router Tuning ────────────────────────────────────────────────────────

# [optional] TTL for pending commands before auto-expiry (minutes). Default: 30
# PENDING_COMMAND_TTL_MINUTES=30

# [optional] How often to sweep for expired pending commands (ms). Default: 60000
# EXPIRY_SWEEP_INTERVAL_MS=60000

# [optional] Max recent turns loaded into LangGraph context. Default: 10
# MAX_CONVERSATION_TURNS=10

# [optional] Confidence threshold for auto-confirming commands (0-1). Default: 0.95
# AUTO_CONFIRM_CONFIDENCE_THRESHOLD=0.95


# ── Guardrails (ai-router, voice-transcription) ─────────────────────────────
# Per-user rate limits, concurrency caps, and budget tracking for OpenAI usage.

# [optional] Max requests per user per window. Default: 30
# GUARDRAIL_RATE_LIMIT_PER_USER=30

# [optional] Rate limit window in seconds. Default: 60
# GUARDRAIL_RATE_WINDOW_SECONDS=60

# [optional] Max concurrent requests per user. Default: 3
# GUARDRAIL_CONCURRENCY_PER_USER=3

# [optional] Total budget limit in USD (triggers kill switch). Default: 100
# GUARDRAIL_BUDGET_LIMIT_USD=100

# [optional] Budget alarm threshold as percentage of limit. Default: 80
# GUARDRAIL_BUDGET_ALARM_THRESHOLD_PCT=80

# [optional] Estimated cost per LLM request in USD. Default: 0.01
# GUARDRAIL_COST_PER_REQUEST_USD=0.01


# ── Scheduler Tuning ────────────────────────────────────────────────────────

# [optional] Max job-level retries for failed command executions. Default: 3
# SCHEDULER_MAX_RETRIES=3

# [optional] Initial backoff between retries (ms, exponential). Default: 1000
# SCHEDULER_RETRY_BACKOFF_MS=1000

# [optional] Hours to look back for missed reminders (catch-up window). Default: 6
# CATCH_UP_WINDOW_HOURS=6

# [optional] How often to poll for due reminders (ms). Default: 60000
# REMINDER_POLL_INTERVAL_MS=60000


# ── Data Retention (scheduler) ──────────────────────────────────────────────

# [optional] How often to run retention cleanup (ms). Default: 86400000 (24h)
# RETENTION_CLEANUP_INTERVAL_MS=86400000

# [optional] Days to keep conversation turn summaries. Default: 30
# CONVERSATION_RETENTION_DAYS=30

# [optional] Days to keep command execution logs. Default: 90
# COMMAND_LOG_RETENTION_DAYS=90

# [optional] Days to keep idempotency keys. Default: 14
# IDEMPOTENCY_KEY_RETENTION_DAYS=14

# [optional] Days to keep reminder window dedup keys. Default: 14
# REMINDER_WINDOW_RETENTION_DAYS=14


# ── Data Purge (user-management) ────────────────────────────────────────────

# [optional] How often to sweep for pending data purges (ms). Default: 3600000 (1h)
# PURGE_SWEEP_INTERVAL_MS=3600000

# [optional] Minutes before a claimed purge is considered stale. Default: 30
# STALE_CLAIM_THRESHOLD_MINUTES=30

# [optional] Max retries for a failed purge operation. Default: 5
# MAX_PURGE_RETRIES=5


# ── Service Ports ────────────────────────────────────────────────────────────
# [docker-only] These are hardcoded in docker-compose.yml.
# Set these only for local dev when running services directly with tsx.

TELEGRAM_BRIDGE_PORT=3001
AI_ROUTER_PORT=3002
VOICE_TRANSCRIPTION_PORT=3003
MONICA_INTEGRATION_PORT=3004
SCHEDULER_PORT=3005
DELIVERY_PORT=3006
USER_MANAGEMENT_PORT=3007
WEB_UI_PORT=4321


# ── Delivery Connector URLs ─────────────────────────────────────────────────
# [docker-only] Docker Compose hardcodes TELEGRAM_BRIDGE_URL for delivery.
# For local dev, set CONNECTOR_URL_<TYPE> so delivery knows where to send messages.
# At least one connector URL is required.

CONNECTOR_URL_TELEGRAM=http://localhost:3001


# ── Observability ────────────────────────────────────────────────────────────

# [docker-only] OTLP endpoint for traces, metrics, and logs.
# Docker Compose hardcodes this to http://otel-collector:4318.
# For local dev, point to a local collector or leave as-is.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318


# ── Monica Smoke Tests ──────────────────────────────────────────────────────
# Used only by the real-Monica smoke suite (not normal app startup).
# Generated by scripts/seed-monica-smoke.ts into .env.smoke (gitignored).

# MONICA_SMOKE_BASE_URL=http://localhost:8280
# MONICA_SMOKE_API_TOKEN=
