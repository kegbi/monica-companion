# =============================================================================
# Monica Companion — .env for Docker Compose
# Copy to .env.local and fill in real values. Docker Compose loads both files.
# =============================================================================

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=monica                # PostgreSQL superuser name
POSTGRES_PASSWORD=monica_dev        # PostgreSQL superuser password
POSTGRES_DB=monica_companion        # Database name created on first run
DATABASE_URL=postgresql://monica:monica_dev@localhost:15432/monica_companion  # Connection string used by services (host port 15432 maps to container 5432)

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:16379   # Redis connection string (host port 16379 maps to container 6379)

# ── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_MODE=polling               # "polling" for local dev, "webhook" for production
TELEGRAM_BOT_TOKEN=                 # Bot token from @BotFather
TELEGRAM_WEBHOOK_SECRET=            # Random secret sent by Telegram in X-Telegram-Bot-Api-Secret-Token header

# ── AI / LLM ────────────────────────────────────────────────────────────────
LLM_API_KEY=                        # API key for the LLM provider (used by ai-router and voice-transcription)
LLM_BASE_URL=https://api.openai.com/v1  # OpenAI-compatible base URL; change for self-hosted or alternative providers
LLM_MODEL_ID=gpt-5.4-mini          # Model used by ai-router for intent classification and conversation

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production                                          # HMAC secret for service-to-service JWTs (min 32 chars)
JWT_SECRET_PREVIOUS=                                                        # Previous JWT secret for zero-downtime key rotation (optional)
ENCRYPTION_MASTER_KEY=change-me-in-production-generate-a-real-64-hex-char-key-now  # 64 hex-char key for encrypting credentials at rest
ENCRYPTION_MASTER_KEY_PREVIOUS=                                             # Previous encryption key for zero-downtime rotation (optional)

# ── Setup Tokens ─────────────────────────────────────────────────────────────
SETUP_TOKEN_SECRET=change-me-in-production-at-least-32-chars  # HMAC secret for signed onboarding setup links (min 32 chars)
SETUP_BASE_URL=http://127.0.0.1     # Public base URL for setup links sent to users via Telegram
EXPECTED_ORIGIN=http://127.0.0.1    # Origin header value expected by CSRF protection on web-ui forms

# ── Monica API (dev/test only) ──────────────────────────────────────────────
MONICA_BASE_URL=                    # Monica instance URL (e.g. https://app.monicahq.com or self-hosted)
MONICA_API_TOKEN=                   # Personal API token from Monica settings (dev/test only; prod uses per-user encrypted tokens)
MONICA_DEFAULT_TIMEOUT_MS=10000     # HTTP timeout for Monica API calls
MONICA_RETRY_MAX=2                  # Max transport-level retries for failed Monica API calls
ALLOW_PRIVATE_NETWORK_TARGETS=false # Allow RFC1918/loopback Monica URLs (only for local dev with self-hosted Monica)

# ── Voice Transcription ─────────────────────────────────────────────────────
WHISPER_MODEL=gpt-4o-transcribe     # Transcription model: whisper-1, gpt-4o-transcribe, or gpt-4o-mini-transcribe
WHISPER_TIMEOUT_MS=60000            # Timeout for a single transcription request
WHISPER_MAX_FILE_SIZE_BYTES=26214400  # Max upload size (25 MB, OpenAI limit)
FETCH_URL_TIMEOUT_MS=15000          # Timeout when fetching audio from a remote URL before transcription

# ── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000          # Sliding window duration for Telegram webhook rate limiting
RATE_LIMIT_MAX_REQUESTS=60          # Max requests per window per source IP

# ── Service Timeouts ────────────────────────────────────────────────────────
AI_ROUTER_TIMEOUT_MS=10000          # telegram-bridge timeout when calling ai-router
VOICE_TRANSCRIPTION_TIMEOUT_MS=30000  # telegram-bridge timeout when calling voice-transcription
USER_MANAGEMENT_TIMEOUT_MS=5000     # telegram-bridge timeout when calling user-management
HTTP_TIMEOUT_MS=10000               # Default inter-service HTTP timeout (scheduler, delivery)

# ── Service Ports ────────────────────────────────────────────────────────────
TELEGRAM_BRIDGE_PORT=3001
AI_ROUTER_PORT=3002
VOICE_TRANSCRIPTION_PORT=3003
MONICA_INTEGRATION_PORT=3004
SCHEDULER_PORT=3005
DELIVERY_PORT=3006
USER_MANAGEMENT_PORT=3007
WEB_UI_PORT=4321

# ── Delivery Connector URLs ─────────────────────────────────────────────────
CONNECTOR_URL_TELEGRAM=http://localhost:3001  # URL delivery uses to reach the Telegram connector

# ── Observability ────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318  # OpenTelemetry Collector OTLP/HTTP endpoint (requires --profile observability)
