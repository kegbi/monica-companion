# =============================================================================
# Monica Companion — .env for Docker Compose
# =============================================================================

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=monica
POSTGRES_PASSWORD=monica_dev
POSTGRES_DB=monica_companion
DATABASE_URL=postgresql://monica:monica_dev@localhost:15432/monica_companion

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:16379

# ── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_MODE=
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# ── AI / LLM ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=
LLM_MODEL_ID=qwen/qwen3-235b-a22b

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_SECRET_PREVIOUS=
ENCRYPTION_MASTER_KEY=change-me-in-production-generate-a-real-64-hex-char-key-now
ENCRYPTION_MASTER_KEY_PREVIOUS=

# ── Setup Tokens ─────────────────────────────────────────────────────────────
SETUP_TOKEN_SECRET=change-me-in-production-at-least-32-chars
SETUP_BASE_URL=http://127.0.0.1
EXPECTED_ORIGIN=http://127.0.0.1

# ── Monica API (dev/test only) ──────────────────────────────────────────────
MONICA_BASE_URL=
MONICA_API_TOKEN=
MONICA_DEFAULT_TIMEOUT_MS=10000
MONICA_RETRY_MAX=2
ALLOW_PRIVATE_NETWORK_TARGETS=false

# ── Voice Transcription ─────────────────────────────────────────────────────
WHISPER_MODEL=gpt-4o-transcribe
WHISPER_TIMEOUT_MS=60000
WHISPER_MAX_FILE_SIZE_BYTES=26214400
FETCH_URL_TIMEOUT_MS=15000

# ── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60

# ── Service Timeouts ────────────────────────────────────────────────────────
AI_ROUTER_TIMEOUT_MS=10000
VOICE_TRANSCRIPTION_TIMEOUT_MS=30000
USER_MANAGEMENT_TIMEOUT_MS=5000
HTTP_TIMEOUT_MS=10000

# ── Service Ports ────────────────────────────────────────────────────────────
TELEGRAM_BRIDGE_PORT=3001
AI_ROUTER_PORT=3002
VOICE_TRANSCRIPTION_PORT=3003
MONICA_INTEGRATION_PORT=3004
SCHEDULER_PORT=3005
DELIVERY_PORT=3006
USER_MANAGEMENT_PORT=3007
WEB_UI_PORT=4321

# ── Delivery Connector URLs ─────────────────────────────────────────────────
CONNECTOR_URL_TELEGRAM=http://localhost:3001

# ── Observability ────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
