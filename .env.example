# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=monica
POSTGRES_PASSWORD=monica_dev
POSTGRES_DB=monica_companion
DATABASE_URL=postgresql://monica:monica_dev@localhost:5432/monica_companion

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# ── Rate Limiting ────────────────────────────────────────────────────────────
# Fixed-window rate limiter for the Telegram webhook endpoint
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60

# ── Monica API ────────────────────────────────────────────────────────────────
# Per-user credentials are stored encrypted in the database.
# These are only used for development/testing.
MONICA_BASE_URL=
MONICA_API_TOKEN=
# Transport-level settings for the Monica API client in monica-integration
MONICA_DEFAULT_TIMEOUT_MS=10000
MONICA_RETRY_MAX=2
# SECURITY: Allow Monica URLs targeting private/loopback IPs (e.g., single-tenant LAN deployments).
# Set to "true" ONLY for trusted environments where Monica runs on a private network.
# Default "false" blocks http://, loopback, RFC1918, and link-local targets (SSRF protection).
ALLOW_PRIVATE_NETWORK_TARGETS=false

# ── AI / LLM ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_SECRET_PREVIOUS=
ENCRYPTION_MASTER_KEY=change-me-in-production

# ── Setup Tokens ─────────────────────────────────────────────────────────────
# Must be at least 32 characters, cryptographically random, distinct from JWT_SECRET
SETUP_TOKEN_SECRET=change-me-in-production-at-least-32-chars
# Public-facing URL where the setup page is accessible (via Caddy)
SETUP_BASE_URL=http://localhost
# Expected origin for CSRF validation in web-ui
EXPECTED_ORIGIN=http://localhost

# ── Service Ports ─────────────────────────────────────────────────────────────
TELEGRAM_BRIDGE_PORT=3001
AI_ROUTER_PORT=3002
VOICE_TRANSCRIPTION_PORT=3003
MONICA_INTEGRATION_PORT=3004
SCHEDULER_PORT=3005
DELIVERY_PORT=3006
USER_MANAGEMENT_PORT=3007
WEB_UI_PORT=4321

# ── Observability ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
