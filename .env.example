# =============================================================================
# Monica Companion — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Lines marked [required] must be set before starting the stack.
# Lines with defaults can be left as-is for local development.
# =============================================================================

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL credentials used by docker-compose to create the database
# and by all services that need a DB connection.

# Username for the PostgreSQL database.
POSTGRES_USER=monica

# Password for the PostgreSQL database.
POSTGRES_PASSWORD=monica_dev

# Name of the database to create/use.
POSTGRES_DB=monica_companion

# Full connection string used by services. Host/port must match docker-compose
# port mapping (15432 on host -> 5432 in container).
DATABASE_URL=postgresql://monica:monica_dev@localhost:15432/monica_companion

# ── Redis ────────────────────────────────────────────────────────────────────
# Used for rate limiting, guardrails, job queues (BullMQ), and caching.
# Host/port must match docker-compose port mapping (16379 on host -> 6379 in container).

REDIS_URL=redis://localhost:16379

# ── Telegram ─────────────────────────────────────────────────────────────────

# [required] Bot token from @BotFather (https://t.me/BotFather).
TELEGRAM_BOT_TOKEN=

# How the bot receives updates: "polling" for local dev, "webhook" for production.
# Polling requires no public URL. Webhook requires HTTPS + public endpoint.
# Default: webhook
TELEGRAM_MODE=polling

# Secret token for webhook verification. Telegram sends this in the
# X-Telegram-Bot-Api-Secret-Token header. Required when TELEGRAM_MODE=webhook.
TELEGRAM_WEBHOOK_SECRET=

# ── AI / LLM ────────────────────────────────────────────────────────────────

# [required] OpenAI API key (https://platform.openai.com/api-keys).
# Used by voice-transcription service for Whisper speech-to-text.
OPENAI_API_KEY=

# [required] API key for the LLM chat completion provider.
# Used by ai-router for the conversational agent loop.
# Can be the same as OPENAI_API_KEY if using OpenAI directly,
# or a different key for OpenRouter, Ollama, vLLM, etc.
LLM_API_KEY=

# Base URL for the LLM API. Must be OpenAI-compatible (chat/completions endpoint).
# Examples:
#   OpenAI direct:   https://api.openai.com/v1
#   OpenRouter:      https://openrouter.ai/api/v1
#   Local Ollama:    http://localhost:11434/v1
# Default: https://openrouter.ai/api/v1
LLM_BASE_URL=https://openrouter.ai/api/v1

# Model identifier passed to the LLM API.
# Must match the provider's model naming (e.g. "gpt-4o" for OpenAI,
# "qwen/qwen3-235b-a22b" for OpenRouter, "llama3" for Ollama).
# Default: qwen/qwen3-235b-a22b
LLM_MODEL_ID=qwen/qwen3-235b-a22b

# ── Auth ─────────────────────────────────────────────────────────────────────
# Service-to-service JWT authentication. All services share these secrets
# to sign and verify internal API calls.

# [required] Primary JWT signing secret. Use a random 64+ hex char string.
# Generate with: openssl rand -hex 64
JWT_SECRET=change-me-in-production

# Previous JWT secret for zero-downtime key rotation.
# When set, services accept tokens signed with either key but only sign with the current one.
# Leave empty unless rotating keys.
JWT_SECRET_PREVIOUS=

# [required] AES-256 key for encrypting MonicaHQ API credentials at rest in PostgreSQL.
# Must be 32+ bytes, encoded as hex (64 chars), base64, or base64url.
# Generate with: openssl rand -hex 32
ENCRYPTION_MASTER_KEY=change-me-in-production-generate-a-real-64-hex-char-key-now

# Previous encryption key for zero-downtime rotation. Same format as ENCRYPTION_MASTER_KEY.
ENCRYPTION_MASTER_KEY_PREVIOUS=

# ── Setup / Onboarding ──────────────────────────────────────────────────────
# Controls the one-time setup flow where users connect their MonicaHQ account
# via a signed link sent through the Telegram bot.

# [required] Secret for signing setup tokens (HMAC). Min 32 chars.
# Generate with: openssl rand -hex 32
SETUP_TOKEN_SECRET=change-me-in-production-at-least-32-chars

# Base URL for setup links sent to users. Must point to the web-ui service.
# In production this is your public HTTPS domain; for local dev use localhost.
SETUP_BASE_URL=http://127.0.0.1

# Expected Origin header for CSRF protection on onboarding form submissions.
# Must match the origin users see in their browser.
EXPECTED_ORIGIN=http://127.0.0.1

# ── Monica API ───────────────────────────────────────────────────────────────
# MonicaHQ CRM connection settings. In production, credentials are per-user
# and stored encrypted in PostgreSQL. These vars are for dev/test only.

# URL of the MonicaHQ instance (e.g. https://app.monicahq.com or self-hosted).
MONICA_BASE_URL=

# Personal API token from MonicaHQ (Settings -> API). For dev/test seeding only.
MONICA_API_TOKEN=

# Timeout for individual Monica API calls (ms). Default: 10000
MONICA_DEFAULT_TIMEOUT_MS=10000

# Max retries for failed Monica API calls (transport-level). Default: 2
MONICA_RETRY_MAX=2

# Allow connections to private/loopback IPs (RFC1918, 127.0.0.0/8).
# Set to "true" only for local self-hosted Monica instances. Default: false
ALLOW_PRIVATE_NETWORK_TARGETS=false

# ── Voice Transcription ─────────────────────────────────────────────────────
# Configuration for the voice-transcription service that converts voice
# messages to text using OpenAI's Whisper API.

# Whisper model to use. Options: whisper-1, gpt-4o-transcribe, gpt-4o-mini-transcribe.
# Default: gpt-4o-transcribe
WHISPER_MODEL=gpt-4o-transcribe

# Timeout for Whisper API calls (ms). Default: 60000
WHISPER_TIMEOUT_MS=60000

# Max audio file size accepted (bytes). Default: 26214400 (25 MiB)
WHISPER_MAX_FILE_SIZE_BYTES=26214400

# Timeout for fetching audio from URLs when using URL input mode (ms). Default: 15000
FETCH_URL_TIMEOUT_MS=15000

# ── Rate Limiting ────────────────────────────────────────────────────────────
# Global rate limiting applied by telegram-bridge on incoming Telegram updates.

# Time window for rate limiting (ms). Default: 60000 (1 min)
RATE_LIMIT_WINDOW_MS=60000

# Max requests allowed per window. Default: 60
RATE_LIMIT_MAX_REQUESTS=60

# ── Guardrails ───────────────────────────────────────────────────────────────
# Per-user guardrails applied by ai-router and voice-transcription.
# All values have sensible defaults; only override if needed.

# Max requests per user within the rate window. Default: 30
# GUARDRAIL_RATE_LIMIT_PER_USER=30

# Rate window duration (seconds). Default: 60
# GUARDRAIL_RATE_WINDOW_SECONDS=60

# Max concurrent requests per user. Default: 3
# GUARDRAIL_CONCURRENCY_PER_USER=3

# Daily spend limit per user (USD). Default: 100
# GUARDRAIL_BUDGET_LIMIT_USD=100

# Budget alarm triggers at this % of the limit. Default: 80
# GUARDRAIL_BUDGET_ALARM_THRESHOLD_PCT=80

# Estimated cost charged per request (USD). Default: 0.01
# GUARDRAIL_COST_PER_REQUEST_USD=0.01

# ── Service Timeouts ─────────────────────────────────────────────────────────
# Timeouts for inter-service HTTP calls made by telegram-bridge.

# Timeout for ai-router calls (ms). Default: 10000
AI_ROUTER_TIMEOUT_MS=10000

# Timeout for voice-transcription calls (ms). Default: 30000
VOICE_TRANSCRIPTION_TIMEOUT_MS=30000

# Timeout for user-management calls (ms). Default: 5000
USER_MANAGEMENT_TIMEOUT_MS=5000

# General HTTP timeout used by scheduler and delivery (ms). Default: 10000
HTTP_TIMEOUT_MS=10000

# ── Service Ports ────────────────────────────────────────────────────────────
# Internal ports each service listens on. These are mapped in docker-compose;
# override only if you have port conflicts.

TELEGRAM_BRIDGE_PORT=3001
AI_ROUTER_PORT=3002
VOICE_TRANSCRIPTION_PORT=3003
MONICA_INTEGRATION_PORT=3004
SCHEDULER_PORT=3005
DELIVERY_PORT=3006
USER_MANAGEMENT_PORT=3007
WEB_UI_PORT=4321

# ── Delivery Connector URLs ─────────────────────────────────────────────────
# delivery service uses CONNECTOR_URL_<TYPE> to discover outbound connectors.
# At least one connector must be configured. For Telegram-only setup:

CONNECTOR_URL_TELEGRAM=http://localhost:3001

# ── Data Retention ───────────────────────────────────────────────────────────
# Scheduler periodically cleans up old data. These control retention periods.
# All values have defaults; only override if needed.

# How often the cleanup job runs (ms). Default: 86400000 (24h)
# RETENTION_CLEANUP_INTERVAL_MS=86400000

# Keep conversation history for this many days. Default: 30
# CONVERSATION_RETENTION_DAYS=30

# Keep command execution logs for this many days. Default: 90
# COMMAND_LOG_RETENTION_DAYS=90

# Keep idempotency keys for this many days. Default: 14
# IDEMPOTENCY_KEY_RETENTION_DAYS=14

# Keep reminder dedup windows for this many days. Default: 14
# REMINDER_WINDOW_RETENTION_DAYS=14

# ── Observability ────────────────────────────────────────────────────────────
# OpenTelemetry collector endpoint for logs, metrics, and traces.
# Points to the otel-collector container in docker-compose.

OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
