:80 {
	header -Server

	handle /webhook/telegram* {
		request_body {
			max_size 1MB
		}
		reverse_proxy telegram-bridge:3001
	}

	handle /setup* {
		request_body {
			max_size 512KB
		}
		header X-Content-Type-Options "nosniff"
		header X-Frame-Options "DENY"
		header Referrer-Policy "strict-origin-when-cross-origin"
		reverse_proxy web-ui:4321
	}

	# Astro/Vite dev assets — required for dev mode CSS/JS loading
	handle /@vite/* {
		reverse_proxy web-ui:4321
	}
	handle /@id/* {
		reverse_proxy web-ui:4321
	}
	handle /src/* {
		reverse_proxy web-ui:4321
	}
	handle /node_modules/* {
		reverse_proxy web-ui:4321
	}

	respond "Not Found" 404
}
